{
  "entities": {
    "Site": {
      "title": "Site",
      "description": "Mining site definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "managerId": { "type": "string" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "Platform user with roles and site access",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["secretary", "responsible", "chief", "direction", "admin"] },
        "siteIds": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["email", "role"]
    },
    "Production": {
      "title": "Production",
      "description": "Daily production record for a chantier",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "siteId": { "type": "string" },
        "post": { "type": "string", "enum": ["Poste 1", "Poste 2", "Poste 3"] },
        "sector": { "type": "string" },
        "chantierId": { "type": "string" },
        "operatorId": { "type": "string" },
        "chiefName": { "type": "string" },
        "minerName": { "type": "string" },
        "assistantName": { "type": "string" },
        "drillModel": { "type": "string" },
        "barLength": { "type": "number" },
        "gallerySize": { "type": "number" },
        "holeCount": { "type": "number" },
        "meterage": { "type": "number" },
        "meteragePlanned": { "type": "number" },
        "rounds": { "type": "number" },
        "explosives": {
          "type": "object",
          "properties": {
            "anfo": { "type": "number" },
            "tovex": { "type": "number" },
            "ammorces": { "type": "number" }
          }
        },
        "fuelConsumption": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending_validation", "validated"] },
        "validatedBy": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string" }
      },
      "required": ["date", "siteId", "chantierId", "post", "meterage"]
    },
    "Chantier": {
      "title": "Chantier",
      "description": "Specific mining advancement area",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "siteId": { "type": "string" },
        "sector": { "type": "string" },
        "managerName": { "type": "string" },
        "galleryType": { "type": "string", "enum": ["9m2", "12m2"] },
        "status": { "type": "string", "enum": ["ouvert", "fermé"] },
        "targetMeterage": { "type": "number" }
      },
      "required": ["name", "siteId", "status"]
    },
    "Engine": {
      "title": "Engine",
      "description": "Mining equipment/machinery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["perforateur", "camion", "pelle", "autre"] },
        "siteId": { "type": "string" },
        "status": { "type": "string", "enum": ["operational", "maintenance", "broken"] },
        "engineHours": { "type": "number" },
        "fuelLevel": { "type": "number" },
        "lastMaintenanceDate": { "type": "string" }
      },
      "required": ["id", "name", "type"]
    },
    "MaintenanceOrder": {
      "title": "MaintenanceOrder",
      "description": "Service record for engines",
      "type": "object",
      "properties": {
        "engineId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["preventive", "corrective"] },
        "description": { "type": "string" },
        "cost": { "type": "number" },
        "technicianId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed"] }
      },
      "required": ["engineId", "date", "type"]
    },
    "Stock": {
      "title": "Stock",
      "description": "Consumables inventory per site",
      "type": "object",
      "properties": {
        "siteId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minThreshold": { "type": "number" }
      },
      "required": ["siteId", "itemName", "quantity"]
    },
    "Personnel": {
      "title": "Personnel",
      "description": "Mining staff database",
      "type": "object",
      "properties": {
        "matricule": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "fonction": { "type": "string" },
        "siteId": { "type": "string" },
        "status": { "type": "string", "enum": ["actif", "inactif"] }
      },
      "required": ["matricule", "nom", "prenom", "fonction"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Traceability log for all sensitive actions",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "object" },
        "geo": { "type": "object" }
      },
      "required": ["timestamp", "userId", "action"]
    },
    "DailyPlanningSheet": {
      "title": "DailyPlanningSheet",
      "description": "Sheet status representing a plan for a given day and post",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "post": { "type": "string" },
        "status": { "type": "string" },
        "chiefName": { "type": "string" },
        "lastSavedBy": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["date", "post"]
    },
    "Planning": {
      "title": "Planning",
      "description": "Individual assignment item inside a planning list",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "post": { "type": "string" },
        "chantierId": { "type": "string" },
        "engineCode": { "type": "string" },
        "minerMatricule": { "type": "string" },
        "assistantMatricule": { "type": "string" }
      },
      "required": ["date", "post", "chantierId"]
    },
    "DailyExcelSheet": {
      "title": "DailyExcelSheet",
      "description": "Dynamic daily spreadsheet logs saves",
      "type": "object",
      "properties": {
        "minageRows": { "type": "array" },
        "deblayageRows": { "type": "array" },
        "extractionRows": { "type": "array" },
        "maintenanceRows": { "type": "array" },
        "pressionReseau": { "type": "string" },
        "tensionLigne": { "type": "string" },
        "qualiteAire": { "type": "string" }
      }
    },
    "ProductionHistory": {
      "title": "ProductionHistory",
      "description": "Internal logs tracking sheet validations and locks",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/sites": { "schema": "Site", "description": "Mining sites" },
    "/users": { "schema": "User", "description": "System users" },
    "/production": { "schema": "Production", "description": "Production logs" },
    "/chantiers": { "schema": "Chantier", "description": "Chantier registry" },
    "/engines": { "schema": "Engine", "description": "Equipment registry" },
    "/maintenance": { "schema": "MaintenanceOrder", "description": "Maintenance history" },
    "/stocks": { "schema": "Stock", "description": "Inventory management" },
    "/logs": { "schema": "AuditLog", "description": "Security and audit trail" },
    "/personnel": { "schema": "Personnel", "description": "Employee database" },
    "/daily_planning_sheets": { "schema": "DailyPlanningSheet", "description": "Daily planning sheet records" },
    "/planning": { "schema": "Planning", "description": "Planning assignments" },
    "/daily_excel_sheets": { "schema": "DailyExcelSheet", "description": "Consolidated spreadsheet saves" },
    "/production_history": { "schema": "ProductionHistory", "description": "Workbook validation and action logs" }
  }
}

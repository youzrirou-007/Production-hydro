rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function hasRole(roles) {
      let data = getUserData();
      return isSignedIn() && data != null && ('role' in data) && (data.role in roles);
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Sites
    match /sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin']);
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || hasRole(['admin']));
      allow update: if isSignedIn() && (request.auth.uid == userId || hasRole(['admin']));
    }

    // Production
    match /production/{prodId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() 
        && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary'])
        && request.resource.data.date == prodId;
    }

    // Chantiers
    match /chantiers/{cId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief']);
    }

    // Personnel
    match /personnel/{pId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief']);
    }

    // Engines
    match /engines/{engineId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'chief', 'responsible']);
    }

    // Maintenance
    match /maintenance/{mId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'chief']);
    }

    // Stocks
    match /stocks/{sId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'chief']);
    }

    // Logs
    match /logs/{logId} {
      allow read: if isSignedIn() && hasRole(['admin', 'direction']);
      allow create: if isSignedIn();
    }

    // Audit Logs (déscellement, opérations sensibles)
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole(['admin', 'direction']);
      allow create: if isSignedIn() && hasRole(['admin', 'direction']);
      allow update, delete: if false;
    }

    // Daily Planning Sheets
    match /daily_planning_sheets/{sheetId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
        && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary'])
        && request.resource.data.date == sheetId;
      allow delete: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);

      match /modification_requests/{requestId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && hasRole(['admin', 'direction']);
        allow delete: if isSignedIn() && hasRole(['admin', 'direction']);
      }
    }

    // Deleted Plannings Log
    match /deleted_plannings_log/{logId} {
      allow read: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
      allow create: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
      allow update, delete: if false;
    }

    // Rotations History
    match /rotations_history/{rotationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
    }

    // Rotations Drafts
    match /rotations_drafts/{draftId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
    }

    // Planning
    match /planning/{planId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
    }

    // Production History
    match /production_history/{histId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
    }

    // Settings
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin', 'direction', 'chief']);
    }

    // Platform Settings
    match /platform_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && hasRole(['admin']);
    }

    // Non Realisation Explanations
    match /non_realisation_explanations/{expId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasRole(['admin', 'direction', 'chief', 'responsible', 'secretary']);
      allow update, delete: if isSignedIn() && hasRole(['admin', 'direction', 'chief']);
    }

    // Modification Requests subcollection & collection group
    match /{path=**}/modification_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && hasRole(['admin', 'direction']);
      allow delete: if isSignedIn() && hasRole(['admin', 'direction']);
    }

    // System Messages (Notifications, Messenger, Read Status & Draft Telemetry)
    match /system_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasRole(['admin', 'direction']);
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && hasRole(['admin', 'direction']);
    }
  }
}
